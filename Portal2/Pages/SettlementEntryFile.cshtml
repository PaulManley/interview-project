@page
@model SettlementEntryFileModel
@{
	ViewData["Title"] = "Settlement Entry File";
}

<div class="container-fluid mt-5">
	<div class="row mb-4">
		<div class="col-md-6">
			<h1>Settlement Entry File</h1>
		</div>
		<div class="col-md-6 text-end">
			<a href="@Url.Page("UploadFilesAndRunReconciliation")" class="btn btn-secondary">Upload Another File</a>
		</div>
	</div>

	@if (!string.IsNullOrEmpty(Model.ErrorMessage))
	{
		<div class="alert alert-danger alert-dismissible fade show" role="alert">
			@Model.ErrorMessage
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	}

	@if (Model.SettlementEntries == null || Model.SettlementEntries.Length == 0)
	{
		<div class="alert alert-info">
			No settlement entries found for this file.
		</div>
	}
	else
	{
		<div class="table-responsive">
			<table class="table table-striped table-hover">
				<thead class="table-dark">
					<tr>
						<th>Tran Link</th>
						<th>Network Ref</th>
						<th>Merchant Ref</th>
						<th>Merchant ID</th>
						<th>Card Type</th>
						<th>Card Last 4</th>
						<th>Settled Amount</th>
						<th>Interchange Fee</th>
						<th>Processor Fee</th>
						<th>Currency</th>
						<th>Settlement Date</th>
						<th>Status</th>
						<th>Error</th>
						<th>Notification</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var entry in Model.SettlementEntries)
					{
						<tr>
							<td>
								@if (entry.TransactionLedgerId.HasValue && entry.TransactionLedgerId.Value != Guid.Empty)
								{
									<a href="@Url.Page("TransactionLedgerDetail", new { transactionLedgerId = entry.TransactionLedgerId.Value })">
										View Transaction
									</a>
								}
								else
								{
									<span style="color: #ff8c00; font-weight: bold;">Not Reconciled</span>
								}
							</td>
							<td>@entry.NetworkRef</td>
							<td>@entry.MerchantRef</td>
							<td>@entry.MerchantId</td>
							<td>@entry.CardType</td>
							<td>@entry.CardLast4</td>
							<td>
								@if (entry.SettledAmountCents.HasValue)
								{
									@($"{entry.SettledAmountCents.Value / 100.0:F2}")
								}
							</td>
							<td>
								@if (entry.InterchangeFeeCents.HasValue)
								{
									@($"{entry.InterchangeFeeCents.Value / 100.0:F2}")
								}
							</td>
							<td>
								@if (entry.ProcessorFeeCents.HasValue)
								{
									@($"{entry.ProcessorFeeCents.Value / 100.0:F2}")
								}
							</td>
							<td>@entry.Currency</td>
							<td>@entry.SettlementDate?.ToString("yyyy-MM-dd")</td>
							<td>
								@if (!string.IsNullOrEmpty(entry.Status))
								{
									<span class="badge bg-secondary">@entry.Status</span>
								}
							</td>
							<td>
								@if (!string.IsNullOrEmpty(entry.Error))
								{
									<span class="text-danger">@entry.Error</span>
								}
							</td>
							<td>
								@if ( !string.IsNullOrEmpty( entry.Notification ) )
								{
									<span class="text-warn">@entry.Notification</span>
								}
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>

		<div class="mt-4">
			<p class="text-muted">
				Total Records: <strong>@Model.SettlementEntries.Length</strong>
			</p>
		</div>
	}
</div>
