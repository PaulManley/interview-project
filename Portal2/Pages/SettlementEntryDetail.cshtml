@page
@model SettlementEntryDetailModel
@{
	ViewData["Title"] = "Settlement Entry Detail";
}

<div class="container mt-5">
	<div class="row mb-4">
		<div class="col-md-8">
			<h1>Settlement Entry Detail</h1>
		</div>
		<div class="col-md-4 text-end">
			<form method="post" asp-page-handler="ClearMatching" class="d-inline">
				<input type="hidden" name="settlementEntryId" value="@Model.SettlementEntryId" />
				<button type="submit" class="btn btn-warning">Clear Matching</button>
			</form>
			<a href="@Url.Page("UploadFilesAndRunReconciliation")" class="btn btn-secondary">Back to Upload</a>
		</div>
	</div>

	@if (!string.IsNullOrEmpty(Model.ErrorMessage))
	{
		<div class="alert alert-danger alert-dismissible fade show" role="alert">
			@Model.ErrorMessage
			<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
		</div>
	}

	@if (Model.Settlement == null)
	{
		<div class="alert alert-info">
			No settlement entry found for this ID.
		</div>
	}
	else
	{
		<div class="accordion mb-4" id="fileStatsAccordion">
			<div class="accordion-item">
				<h2 class="accordion-header" id="fileStatsHeader">
					<button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#fileStatsPanel" aria-expanded="false" aria-controls="fileStatsPanel">
						Overall File Stats
					</button>
				</h2>
				<div id="fileStatsPanel" class="accordion-collapse collapse" aria-labelledby="fileStatsHeader" data-bs-parent="#fileStatsAccordion">
					<div class="accordion-body">
						@if (Model.FileStatusStats == null || Model.FileStatusStats.Length == 0)
						{
							<p class="text-muted mb-0">No stats available.</p>
						}
						else
						{
							<div class="table-responsive">
								<table class="table table-sm table-striped mb-0">
									<thead class="table-light">
										<tr>
											<th>Status</th>
											<th>Count</th>
											<th>Amount</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var stat in Model.FileStatusStats)
										{
											<tr>
												<td>@stat.Status</td>
												<td>@stat.Count</td>
												<td>@($"{stat.AmountCents / 100.0:F2}")</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						}
					</div>
				</div>
			</div>
		</div>

		<div class="row">
			<div class="col-md-8">
				<div class="card mb-4">
					<div class="card-header bg-primary text-white">
						<h5 class="mb-0">Settlement Information</h5>
					</div>
					<div class="card-body">
						<div class="row mb-3">
							<div class="col-md-6">
								<strong>Network Ref:</strong>
								<p>@Model.Settlement.NetworkRef</p>
							</div>
							<div class="col-md-6">
								<strong>Merchant Ref:</strong>
								<p>@Model.Settlement.MerchantRef</p>
							</div>
						</div>

						<div class="row mb-3">
							<div class="col-md-6">
								<strong>Merchant ID:</strong>
								<p>@Model.Settlement.MerchantId</p>
							</div>
							<div class="col-md-6">
								<strong>Card:</strong>
								<p>@Model.Settlement.CardType @Model.Settlement.CardLast4</p>
							</div>
						</div>

						<div class="row mb-3">
							<div class="col-md-6">
								<strong>Settlement Date:</strong>
								<p>@Model.Settlement.SettlementDate?.ToString("yyyy-MM-dd")</p>
							</div>
							<div class="col-md-6">
								<strong>Currency:</strong>
								<p>@Model.Settlement.Currency</p>
							</div>
						</div>
					</div>
				</div>

				<div class="card mb-4">
					<div class="card-header bg-success text-white">
						<h5 class="mb-0">Amount Information</h5>
					</div>
					<div class="card-body">
						<div class="row mb-3">
							<div class="col-md-6">
								<strong>Settled Amount:</strong>
								<p>
									@if (Model.Settlement.SettledAmountCents.HasValue)
									{
										@($"{Model.Settlement.SettledAmountCents.Value / 100.0:F2}")
									}
								</p>
							</div>
							<div class="col-md-6">
								<strong>Expected Gross Original:</strong>
								<p>
									@if (Model.Settlement.ExpectedGrossOriginalCents.HasValue)
									{
										@($"{Model.Settlement.ExpectedGrossOriginalCents.Value / 100.0:F2}")
									}
								</p>
							</div>
						</div>

						<div class="row mb-3">
							<div class="col-md-6">
								<strong>Interchange Fee:</strong>
								<p>
									@if (Model.Settlement.InterchangeFeeCents.HasValue)
									{
										@($"{Model.Settlement.InterchangeFeeCents.Value / 100.0:F2}")
									}
								</p>
							</div>
							<div class="col-md-6">
								<strong>Processor Fee:</strong>
								<p>
									@if (Model.Settlement.ProcessorFeeCents.HasValue)
									{
										@($"{Model.Settlement.ProcessorFeeCents.Value / 100.0:F2}")
									}
								</p>
							</div>
						</div>
					</div>
				</div>

				<div class="card mb-4">
					<div class="card-header bg-warning text-dark">
						<h5 class="mb-0">Status & Error Information</h5>
					</div>
					<div class="card-body">
						<div class="row mb-3">
							<div class="col-md-6">
								<strong>Status:</strong>
								<p>
									@if (!string.IsNullOrEmpty(Model.Settlement.Status))
									{
										<span class="badge bg-secondary">@Model.Settlement.Status</span>
									}
								</p>
							</div>
							<div class="col-md-6">
								<strong>Record Number:</strong>
								<p>@(Model.Settlement.RecordNumber?.ToString() ?? "—")</p>
							</div>
						</div>

						@if (!string.IsNullOrEmpty(Model.Settlement.Error))
						{
							<div class="row mb-3">
								<div class="col-12">
									<strong>Error:</strong>
									<p class="text-danger">@Model.Settlement.Error</p>
								</div>
							</div>
							<div class="row mb-3">
								<div class="col-12">
									<strong>Error Code:</strong>
									<p class="text-danger">@Model.Settlement.ErrorCode</p>
								</div>
							</div>
						}

						@if (!string.IsNullOrEmpty(Model.Settlement.Notification))
						{
							<div class="row mb-3">
								<div class="col-12">
									<strong>Notification:</strong>
									<p>@Model.Settlement.Notification</p>
								</div>
							</div>
						}
					</div>
				</div>
			</div>

			<div class="col-md-4">
				<div class="card mb-4">
					<div class="card-header bg-info text-white">
						<h5 class="mb-0">Quick Info</h5>
					</div>
					<div class="card-body">
						<p>
							<strong>Settlement Entry ID:</strong><br />
							<code>@Model.Settlement.Id</code>
						</p>
						<p>
							<strong>File Import ID:</strong><br />
							<code>@Model.Settlement.FileImportId</code>
						</p>
						<p>
							<strong>Transaction Ledger ID:</strong><br />
							<code>@(Model.Settlement.TransactionLedgerId?.ToString() ?? "—")</code>
						</p>
						<p>
							<strong>Created:</strong><br />
							@Model.Settlement.Created.ToString("yyyy-MM-dd HH:mm:ss")
						</p>
					</div>
				</div>

				<partial name="Shared/_ForceMatchControl" model="Model.ForceMatchControl" />

				<div class="card">
					<div class="card-header bg-dark text-white">
						<h5 class="mb-0">Linked Transactions</h5>
					</div>
					<div class="card-body">
						@if (Model.Transactions == null || Model.Transactions.Length == 0)
						{
							<p class="text-muted mb-0">No linked transaction ledger items.</p>
						}
						else
						{
							@foreach (var tran in Model.Transactions)
							{
								<div class="border rounded p-2 mb-2">
									<div><strong>Id:</strong> <code>@tran.Id</code></div>
									<div><strong>Ref:</strong> @tran.RefTranId</div>
									<div><strong>Merchant:</strong> @tran.MerchantId</div>
									<div><strong>Amount:</strong>
										@if (tran.GrossAmount.HasValue)
										{
											@($"{tran.GrossAmount.Value / 100.0:F2} {tran.Currency}")
										}
									</div>
									<div><strong>Status:</strong> @tran.Status</div>
									<div class="mt-1">
										<a href="@Url.Page("TransactionLedgerDetail", new { transactionLedgerId = tran.Id })">Open transaction detail</a>
									</div>
								</div>
							}
						}
					</div>
				</div>
			</div>
		</div>
	}
</div>
